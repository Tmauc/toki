# ============================================================
# TOKI — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================
# Légende:
#   [REQUIRED]  obligatoire pour que l'app démarre
#   [REQUIRED*] obligatoire pour la feature concernée
#   [OPTIONAL]  peut être laissé vide pour un premier test

# ────────────────────────────────────────────────────────────
# GENERAL
# ────────────────────────────────────────────────────────────
LOCAL_DEVELOPMENT=true         # [REQUIRED] passer à false en prod
BACKEND_PORT=8080              # [REQUIRED]
BASE_API_URL=http://localhost:8080  # [REQUIRED] URL publique du backend

# ────────────────────────────────────────────────────────────
# FIREBASE  →  https://console.firebase.google.com
# Créer un projet, activer Firestore + Auth (Email/Google)
# ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=           # [REQUIRED] ex: toki-prod-xxxxx
FIREBASE_API_KEY=              # [REQUIRED] clé web API
FIREBASE_AUTH_DOMAIN=          # [REQUIRED] ex: toki-prod-xxxxx.firebaseapp.com
GOOGLE_CLOUD_PROJECT=          # [REQUIRED] = FIREBASE_PROJECT_ID

# Clé de compte de service (JSON inline ou chemin fichier)
# Télécharger depuis Firebase > Paramètres projet > Comptes de service
SERVICE_ACCOUNT_JSON=          # [REQUIRED] contenu JSON (ou laisser vide si fichier monté)
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json  # [REQUIRED si fichier]

# Google Cloud Storage buckets (créer dans Firebase Storage)
BUCKET_SPEECH_PROFILES=toki-speech-profiles     # [REQUIRED*] voice biometrics
BUCKET_MEMORIES_RECORDINGS=toki-memories        # [REQUIRED*] audio recordings
BUCKET_CHAT_FILES=toki-chat-files               # [OPTIONAL]
BUCKET_POSTPROCESSING=toki-postprocessing       # [OPTIONAL]
BUCKET_PLUGINS_LOGOS=toki-plugins               # [OPTIONAL]
BUCKET_APP_THUMBNAILS=toki-thumbnails           # [OPTIONAL]

# ────────────────────────────────────────────────────────────
# OPENAI  →  https://platform.openai.com/api-keys
# ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-             # [REQUIRED] LLM principal (résumés, mémoires)

# ────────────────────────────────────────────────────────────
# SPEECH-TO-TEXT — choisir au moins UN provider
# ────────────────────────────────────────────────────────────
# Deepgram (recommandé)  →  https://console.deepgram.com
DEEPGRAM_API_KEY=              # [REQUIRED*] si Deepgram utilisé
DEEPGRAM_SELF_HOSTED_ENABLED=false
# DEEPGRAM_SELF_HOSTED_URL=http://deepgram:8080  # si self-hosted

# Soniox (alternative)  →  https://soniox.com
SONIOX_API_KEY=                # [OPTIONAL]

# Speechmatics  →  https://www.speechmatics.com
SPEECHMATICS_API_KEY=          # [OPTIONAL]

# ────────────────────────────────────────────────────────────
# PINECONE (Vector DB — mémoire sémantique)
# →  https://app.pinecone.io  |  créer index 1536-dim cosine
# ────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_          # [REQUIRED] recherche sémantique
PINECONE_INDEX_NAME=toki        # [REQUIRED] nom de l'index Pinecone

# ────────────────────────────────────────────────────────────
# REDIS  (géré par docker-compose, ne pas modifier sauf custom)
# ────────────────────────────────────────────────────────────
REDIS_DB_HOST=redis             # [REQUIRED] nom du service docker
REDIS_DB_PORT=6379              # [REQUIRED]
REDIS_DB_PASSWORD=              # [OPTIONAL] laisser vide en local

# ────────────────────────────────────────────────────────────
# PUSHER RELAY  (WebSocket bridge App <-> Backend)
# Utilise le service interne docker, ne pas changer en local
# ────────────────────────────────────────────────────────────
PUSHER_MODULE=custom             # [REQUIRED] garder "custom" pour self-hosted
HOSTED_PUSHER_API_URL=http://pusher:8081  # [REQUIRED] service docker pusher

# ────────────────────────────────────────────────────────────
# DIARISATION (Speaker ID)
# Par défaut via service Docker interne
# ────────────────────────────────────────────────────────────
HOSTED_SPEAKER_EMBEDDING_API_URL=http://diarizer:8082/embedding   # [REQUIRED*]
HOSTED_SPEECH_PROFILE_API_URL=http://diarizer:8082/speech-profile # [REQUIRED*]
HOSTED_VAD_API_URL=http://diarizer:8082/vad                       # [REQUIRED*]
PYANNOTE_API_KEY=               # [OPTIONAL] si diarizer cloud

# ────────────────────────────────────────────────────────────
# SÉCURITÉ
# ────────────────────────────────────────────────────────────
ADMIN_KEY=                      # [REQUIRED] clé admin interne (générer: openssl rand -hex 32)
ENCRYPTION_SECRET=              # [REQUIRED] chiffrement données sensibles (openssl rand -hex 32)
METRICS_SECRET=                 # [OPTIONAL]

# ────────────────────────────────────────────────────────────
# FAIR USE (limites d'utilisation — désactiver en dev)
# ────────────────────────────────────────────────────────────
FAIR_USE_ENABLED=false          # [REQUIRED] false en dev local

# ────────────────────────────────────────────────────────────
# INTÉGRATIONS OPTIONNELLES (remplir selon besoin)
# ────────────────────────────────────────────────────────────

# Google Calendar / Tasks
GOOGLE_CLIENT_ID=               # [OPTIONAL]
GOOGLE_CLIENT_SECRET=           # [OPTIONAL]
GOOGLE_MAPS_API_KEY=            # [OPTIONAL]
GOOGLE_TASKS_CLIENT_ID=         # [OPTIONAL]
GOOGLE_TASKS_CLIENT_SECRET=     # [OPTIONAL]

# Apple Sign-In
APPLE_CLIENT_ID=                # [OPTIONAL]
APPLE_KEY_ID=                   # [OPTIONAL]
APPLE_TEAM_ID=                  # [OPTIONAL]
APPLE_PRIVATE_KEY=              # [OPTIONAL]

# LangSmith (debug LLM traces)
LANGSMITH_API_KEY=              # [OPTIONAL]
LANGSMITH_TRACING=false         # [OPTIONAL]
LANGSMITH_PROJECT=toki          # [OPTIONAL]
LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # [OPTIONAL]

# Autres LLM
GROQ_API_KEY=                   # [OPTIONAL] LLM alternatif rapide
GEMINI_API_KEY=                 # [OPTIONAL]

# Intégrations tâches
TODOIST_CLIENT_ID=              # [OPTIONAL]
TODOIST_CLIENT_SECRET=          # [OPTIONAL]
ASANA_CLIENT_ID=                # [OPTIONAL]
ASANA_CLIENT_SECRET=            # [OPTIONAL]
CLICKUP_CLIENT_ID=              # [OPTIONAL]
CLICKUP_CLIENT_SECRET=          # [OPTIONAL]
